{
  "name": "BaristAI Dev Container",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "runServices": [
    "app",
    "db"
  ],
  "shutdownAction": "stopCompose",
  "remoteEnv": {
    "PYTHONPATH": "/workspace/src"
  },
  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt && pip install pre-commit && pre-commit install",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.analysis.extraPaths": [
          "/workspace/src"
        ]
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
